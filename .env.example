# ─────────────────────────────────────────────────────────────────────────────
# SoleDrop Cloudflare provisioning — environment
# Copy to .env.local and fill in, then:  source .env.local
# .env.local is gitignored — never commit it.
# ─────────────────────────────────────────────────────────────────────────────

# == Cloudflare — required by enable-detections.sh ==
# dash.cloudflare.com → My Profile → API Tokens → Create Custom Token.
# Scopes (for the soledrop.co account/zone):
#   Zone   → Zone:Read, WAF:Edit, Waiting Room:Edit
#   Account → Account Rulesets:Edit
#   (Bot Management:Read to report entitlement status)
CLOUDFLARE_API_TOKEN=                 # SENSITIVE
# dash.cloudflare.com → your account → right sidebar
CLOUDFLARE_ACCOUNT_ID=
# dash.cloudflare.com → the soledrop.co zone → right sidebar
CLOUDFLARE_ZONE_ID=

# == SentinelOne HEC — only needed for the DEFERRED Logpush step (not yet automated) ==
# The Cloudflare→S1 Logpush destination the detections ultimately need.
S1_HEC_INGEST_URL=
S1_HEC_INGEST_TOKEN=                  # SENSITIVE
