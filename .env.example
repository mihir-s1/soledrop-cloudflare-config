# ─────────────────────────────────────────────────────────────────────────────
# SoleDrop Cloudflare provisioning — environment
# Copy to .env.local and fill in, then:  source .env.local
# .env.local is gitignored — never commit it.
# ─────────────────────────────────────────────────────────────────────────────

# == Cloudflare — required by enable-detections.sh + logpush-to-s1.sh ==
# dash.cloudflare.com → My Profile → API Tokens → Create Custom Token.
# Scopes (for the soledrop.co account/zone):
#   Zone   → Zone:Read, WAF:Edit, Waiting Room:Edit, Logs:Edit
#   Account → Account Rulesets:Edit
#   (Bot Management:Read to report entitlement status)
CLOUDFLARE_API_TOKEN=                 # SENSITIVE
# dash.cloudflare.com → your account → right sidebar
CLOUDFLARE_ACCOUNT_ID=
# dash.cloudflare.com → the soledrop.co zone → right sidebar
CLOUDFLARE_ZONE_ID=

# == SentinelOne HEC — required by logpush-to-s1.sh ==
# HEC-compatible ingest endpoint (host + path, scheme optional):
S1_HEC_INGEST_URL=ingest.us1.sentinelone.net/services/collector/raw
S1_HEC_INGEST_TOKEN=                  # SENSITIVE — the S1 HEC write token
# Optional overrides (sensible defaults if left unset):
#   S1_HEC_SOURCETYPE=marketplace-cloudflare-latest   # S1 Cloudflare parser sourcetype
#   S1_HEC_AUTH_SCHEME=                                # default empty: native sentinelone:// wants a BARE token
#                                                      #   (set Bearer/Splunk only for a raw splunk:// HEC)
#   SHOP_HOST=shop.soledrop.co                         # http_requests host filter
